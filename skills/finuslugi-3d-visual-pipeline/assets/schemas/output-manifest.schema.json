{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sevranty/finuslugi-3d-visual-pipeline/schemas/output-manifest.schema.json",
  "title": "Finuslugi Visual Output Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "asset",
    "scene_spec",
    "style",
    "transformation_mode",
    "references",
    "execution",
    "output",
    "qa",
    "delivery"
  ],
  "properties": {
    "manifest_version": {"const": "1.1"},
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "version", "candidate_id"],
      "properties": {
        "asset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "candidate_id": {"type": "string", "minLength": 1}
      }
    },
    "scene_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "sha256"],
      "properties": {
        "version": {"const": "1.0"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"enum": ["modern-flat", "silver-gold", "obsidian-gold"]},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}
      }
    },
    "transformation_mode": {
      "enum": [
        "style-transfer",
        "reinterpretation",
        "composition-transfer",
        "object-preservation",
        "brand-adaptation",
        "variation",
        "reference-synthesis",
        "local-correction"
      ]
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roles"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_profile_id",
        "adapter_id",
        "tool",
        "model",
        "requested_mode",
        "selected_mode",
        "required_capabilities",
        "iterations",
        "fallback",
        "limitations"
      ],
      "properties": {
        "runtime_profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*@[0-9]+$"},
        "adapter_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*@[0-9]+$"},
        "tool": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "requested_mode": {"enum": ["generate", "edit", "reference-conditioned", "mask-edit", "upscale"]},
        "selected_mode": {"enum": ["generate", "edit", "reference-conditioned", "mask-edit", "upscale", "mixed"]},
        "required_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "generate",
              "reference-conditioned",
              "edit",
              "mask-edit",
              "multi-reference",
              "identity-preservation",
              "transparent-output",
              "upscale",
              "exact-dimensions",
              "deliver",
              "seed-control"
            ]
          },
          "uniqueItems": true
        },
        "iterations": {"type": "integer", "minimum": 1},
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applied"],
          "properties": {
            "applied": {"type": "boolean"},
            "from_mode": {"enum": ["generate", "edit", "reference-conditioned", "mask-edit", "upscale"]},
            "to_mode": {"enum": ["generate", "edit", "reference-conditioned", "mask-edit", "upscale", "mixed"]},
            "decision": {"enum": ["stop", "ask-for-input", "staged-route", "disclosed-degradation"]},
            "reason": {"type": "string", "minLength": 1},
            "approved_by_user": {"type": "boolean"},
            "risks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
          }
        },
        "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "width_px", "height_px", "file_format", "background_mode", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "width_px": {"type": "integer", "minimum": 512},
        "height_px": {"type": "integer", "minimum": 512},
        "file_format": {"enum": ["png", "webp", "jpg"]},
        "background_mode": {"enum": ["opaque", "transparent"]},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "decision", "critical_defects", "diagnostic_codes"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "decision": {"enum": ["accept", "minor-correction", "revise", "reject"]},
        "critical_defects": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "diagnostic_codes": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}, "uniqueItems": true}
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visible_to_user", "response_non_empty", "delivered_at"],
      "properties": {
        "visible_to_user": {"const": true},
        "response_non_empty": {"const": true},
        "delivered_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
