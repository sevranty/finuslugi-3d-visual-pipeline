{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sevranty/finuslugi-3d-visual-pipeline/schemas/asset-manifest.schema.json",
  "title": "Finuslugi Governed Asset Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "updated_at", "policy", "collections", "assets"],
  "properties": {
    "registry_version": {"const": "2.0"},
    "updated_at": {"type": "string", "format": "date-time"},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_rights_status", "unregistered_binary_policy", "generated_logo_policy", "exploratory_as_style_source", "public_golden_requires"],
      "properties": {
        "default_rights_status": {"const": "blocked"},
        "unregistered_binary_policy": {"const": "reject"},
        "generated_logo_policy": {"const": "reject"},
        "exploratory_as_style_source": {"const": "reject"},
        "public_golden_requires": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "collections": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["collection_id", "path", "purpose", "admission_status", "production_eligible"],
        "properties": {
          "collection_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "path": {"type": "string", "pattern": "^assets/[a-z0-9/_-]+/$"},
          "purpose": {"type": "string", "minLength": 1},
          "admission_status": {"enum": ["controlled", "review-required", "quarantine"]},
          "production_eligible": {"type": "boolean"}
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id", "asset_version", "path", "collection_id", "type", "variant",
          "lifecycle_status", "approval_status", "rights_status", "public_distribution_status",
          "license_scope", "source", "owner", "allowed_backgrounds", "allowed_roles",
          "prohibited_roles", "source_note", "sha256", "supersedes", "deprecated_at"
        ],
        "properties": {
          "asset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "asset_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "path": {"type": "string", "pattern": "^assets/[A-Za-z0-9_./-]+$"},
          "collection_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "type": {"enum": ["brand-logo", "style-anchor", "anti-pattern", "exploratory-reference", "plugin-interface"]},
          "variant": {"type": "string", "minLength": 1},
          "lifecycle_status": {"enum": ["active", "deprecated", "removed"]},
          "approval_status": {"enum": ["approved", "candidate", "rejected"]},
          "rights_status": {"enum": ["cleared", "pending", "blocked"]},
          "public_distribution_status": {"enum": ["approved", "internal-only", "blocked"]},
          "license_scope": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "allowed_backgrounds": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "allowed_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "prohibited_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "source_note": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "supersedes": {"type": ["string", "null"]},
          "deprecated_at": {"type": ["string", "null"]}
        }
      }
    }
  }
}
